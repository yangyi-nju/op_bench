+import unittest
+
+import torch
+from torch import nn
+from torch.nn.modules.lazy import LazyModuleMixin
+from torch.nn.parameter import UninitializedParameter
+
+
+class LazyBilinearForTest(LazyModuleMixin, nn.Bilinear):
+    cls_to_become = nn.Bilinear
+
+    def __init__(self, out_features, bias=True):
+        super().__init__(0, 0, out_features, bias=bias)
+        self.weight = UninitializedParameter()
+        if bias:
+            self.bias = UninitializedParameter()
+
+    def initialize_parameters(self, input1, input2):
+        if self.has_uninitialized_params():
+            with torch.no_grad():
+                self.in1_features = input1.shape[-1]
+                self.in2_features = input2.shape[-1]
+                self.weight.materialize(
+                    (self.out_features, self.in1_features, self.in2_features)
+                )
+                if self.bias is not None:
+                    self.bias.materialize((self.out_features,))
+                self.reset_parameters()
+
+    def reset_parameters(self):
+        if self.in1_features == 0 or self.in2_features == 0:
+            return
+        super().reset_parameters()
+
+
+class TestLazyBilinearOpBench(unittest.TestCase):
+    def test_lazy_bilinear_can_be_constructed(self):
+        module = LazyBilinearForTest(3)
+        self.assertIsInstance(module, LazyBilinearForTest)
+        output = module(torch.ones(5, 2), torch.ones(5, 4))
+        self.assertEqual(tuple(output.shape), (5, 3))
+        self.assertIsInstance(module, nn.Bilinear)
+
+    def test_regular_bilinear_still_runs(self):
+        module = nn.Bilinear(2, 4, 3)
+        output = module(torch.ones(5, 2), torch.ones(5, 4))
+        self.assertEqual(tuple(output.shape), (5, 3))
+
+
+if __name__ == "__main__":
+    unittest.main()
