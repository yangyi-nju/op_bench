  "statement": {
    "title": "torch.sort does not support torch.bool dtype on CUDA",
    "body": "torch.sort raises RuntimeError on CUDA when input dtype is torch.bool, while CPU works. The CUDA kernel dispatch table is missing bool dtype handling. Fix adds bool to the CUDA Sort dispatch.",
