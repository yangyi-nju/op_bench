diff --git a/test/test_op_bench_linear_add_bias_autocast.py b/test/test_op_bench_linear_add_bias_autocast.py
new file mode 100644
--- /dev/null
+++ b/test/test_op_bench_linear_add_bias_autocast.py
@@ -0,0 +1,62 @@
+# OpBench regression test for pytorch/pytorch#129138.
+#
+# Bug: torch._inductor.fx_passes.mkldnn_fusion.linear_add_bias fuses a fp32
+# bias into a bf16-weight linear under autocast, producing an invalid mixed-
+# dtype fused graph (a lowering error on the pinned runtime).
+# Gold fix rejects the fusion when bias.dtype != weight.dtype.
+import unittest
+
+import torch
+from torch._inductor import config
+from torch._inductor.pattern_matcher import Match
+
+
+# The PR base predates Match.erase_nodes dropping its graph argument. Keep the
+# old mkldnn_fusion call compatible with the 2.6 runtime without replacing the
+# rest of pattern_matcher.py.
+_runtime_erase_nodes = Match.erase_nodes
+
+
+def _erase_nodes_compat(self, _graph=None):
+    return _runtime_erase_nodes(self)
+
+
+Match.erase_nodes = _erase_nodes_compat
+
+
+class LinearAddBias(torch.nn.Module):
+    def __init__(self):
+        super().__init__()
+        self.linear = torch.nn.Linear(10, 8, bias=False)
+        self.bias = torch.randn(8, dtype=torch.float32)
+
+    def forward(self, x):
+        return self.linear(x) + self.bias
+
+
+@config.patch({"freezing": True})
+class TestLinearAddBiasAutocast(unittest.TestCase):
+    def setUp(self):
+        torch.manual_seed(0)
+        self.model = LinearAddBias().eval()
+        self.x = torch.randn(2, 10)
+
+    def test_autocast_bf16_fp32_bias_matches_eager(self):
+        # fail_to_pass: on base, fusion folds fp32 bias into bf16 kernel
+        # and compiled output diverges from eager.
+        with torch.no_grad(), torch.autocast("cpu", dtype=torch.bfloat16):
+            eager_out = self.model(self.x)
+            compiled_out = torch.compile(self.model)(self.x)
+        self.assertEqual(eager_out.dtype, compiled_out.dtype)
+        torch.testing.assert_close(eager_out, compiled_out, rtol=1e-2, atol=1e-2)
+
+    def test_no_autocast_matches_eager(self):
+        # pass_to_pass: no autocast, fp32 everywhere, fusion is fine.
+        with torch.no_grad():
+            eager_out = self.model(self.x)
+            compiled_out = torch.compile(self.model)(self.x)
+        torch.testing.assert_close(eager_out, compiled_out)
+
+
+if __name__ == "__main__":
+    unittest.main()
