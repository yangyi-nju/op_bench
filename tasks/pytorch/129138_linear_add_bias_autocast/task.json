  "statement": {
    "title": "Inductor linear_add_bias fusion wrongly folds fp32 bias when autocast selects bf16 weights",
    "body": "Under `torch.autocast('cpu', dtype=torch.bfloat16)`, the `linear_add_bias` fusion pass in `mkldnn_fusion.py` assumes the bias already has the same dtype as the (autocasted) weight. When the bias is fp32 and the weight is bf16, the pass creates an invalid mixed-dtype fused graph; on the pinned runtime Inductor lowering fails instead of matching eager output. Fix: check that `bias_meta.dtype == weight_meta.dtype` before allowing the fusion.",
    "labels": ["module: inductor", "module: mkldnn", "topic: numerical"]
  },
  "operator": {
    "framework": "pytorch",
    "component": "torch._inductor.fx_passes.mkldnn_fusion",
