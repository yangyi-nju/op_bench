+# OpBench regression test for pytorch/pytorch#139999.
+# torch.masked.mean on a bool input silently accumulates in bool dtype,
+# clamping any count >= 2 to True (1). Gold fix rejects non-floating/complex
+# dtypes with ValueError.
+import unittest
+
+import torch
+
+
+class TestMaskedMeanBoolRaises(unittest.TestCase):
+    def test_masked_mean_bool_raises(self):
+        x = torch.tensor([True, True, True, True])
+        with self.assertRaisesRegex(ValueError, "mean"):
+            torch.masked.mean(x, 0)
+
+    def test_masked_mean_float_still_works(self):
+        # pass_to_pass: normal float mean must keep working after the fix.
+        x = torch.tensor([1.0, 2.0, 3.0, 4.0])
+        result = torch.masked.mean(x, 0)
+        self.assertEqual(result.item(), 2.5)
+
+
+if __name__ == "__main__":
+    unittest.main()
