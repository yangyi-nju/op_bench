  "statement": {
    "title": "CUDA histc does not check min > max for int8 tensors due to low-precision bounds storage",
    "body": "In `_histc_cuda_template`, min/max bounds are stored in `input_t` (the input element type). For `int8`, this means the bounds comparison is done at int8 precision — values can silently wrap or overflow. The expected `RuntimeError` 'max must be larger than min' is never raised for int8 when `min=5, max=1`. Fix: use `at::acc_type<input_t, true>` (a wider type) for the bounds variables so the comparison is numerically correct.",
    "labels": ["module: cuda", "topic: bug fixes", "module: histc"]
  },
  "operator": {
    "framework": "pytorch",
    "component": "aten.native.cuda.histc",
    "operator_name": "torch.histc",
    "problem_type": "integer-bounds-precision",
    "problem_dimension": "precision",
    "problem_subclass": "P5",
    "tags": ["cuda-kernel", "histc", "int8", "bounds-check", "correctness"]
  },
