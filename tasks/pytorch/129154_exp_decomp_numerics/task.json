  "statement": {
    "title": "torch._refs.exponential can produce Inf for inputs near 1.0 due to log(0) underflow",
    "body": "The Python decomp of `exponential_` uses `-1/rate * log1p(-rand_like(self))`. When the uniform sample is exactly 1.0 (valid for `curand_uniform` which samples `(0, 1]`), `log1p(-1.0) = log(0) = -inf`, giving `+inf` as the exponential value. Fix: add an epsilon guard — when `uniform >= 1 - eps/2`, substitute `-eps/2` instead of computing log, matching CUDA's numerical behavior.",
    "labels": ["module: decomposition", "topic: numerical"]
  },
  "operator": {
    "framework": "pytorch",
    "component": "torch._refs.exponential",
    "operator_name": "torch.Tensor.exponential_",
    "problem_type": "log-inf-underflow",
    "problem_dimension": "precision",
    "problem_subclass": "P4",
    "tags": ["exponential", "log", "inf", "cuda", "numerical-stability"]
  },
