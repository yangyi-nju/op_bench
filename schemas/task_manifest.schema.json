{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "op_bench task manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "version",
    "source",
    "statement",
    "operator",
    "environment",
    "agent_visible",
    "evaluation",
    "artifacts",
    "metadata"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "environment_ref": {
      "type": "string",
      "minLength": 1
    },
    "runtime_tier": {
      "type": "string",
      "enum": [
        "cpu-deterministic",
        "single-gpu",
        "kernel-build",
        "cpu_python_overlay",
        "cpu_package_runtime",
        "cpu_source_snapshot_fuller",
        "cuda_declared",
        "cuda_python_overlay",
        "cuda_kernel_build",
        "hardware_specific"
      ]
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "admission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "candidate",
            "draft",
            "environment_ready",
            "source_ready",
            "baseline_reproduced",
            "gold_verified",
            "verified",
            "blocked",
            "blocked_environment",
            "blocked_source",
            "blocked_test",
            "not_reproduced",
            "gold_failed",
            "deprecated"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "verified_at": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "patch_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_paths", "mode"],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "mode": {
          "type": "string",
          "enum": ["enforced", "filtered"]
        }
      }
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pr_url",
        "issue_url",
        "repo",
        "issue_number",
        "pr_number",
        "base_commit",
        "merge_commit"
      ],
      "properties": {
        "pr_url": {
          "type": "string"
        },
        "issue_url": {
          "type": "string"
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "repo_url": {
          "type": "string"
        },
        "issue_number": {
          "type": "integer",
          "minimum": 1
        },
        "pr_number": {
          "type": "integer",
          "minimum": 1
        },
        "base_commit": {
          "type": "string",
          "minLength": 7
        },
        "merge_commit": {
          "type": "string",
          "minLength": 7
        },
        "checkout_mode": {
          "type": "string",
          "enum": [
            "git",
            "local-copy"
          ]
        },
        "local_path": {
          "type": "string"
        },
        "snapshot_path": {
          "type": "string"
        },
        "snapshot_hash": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_method": {
          "type": "string",
          "enum": [
            "from_local_repo",
            "github_archive",
            "git_fetch"
          ]
        }
      }
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "body",
        "labels"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "framework",
        "component",
        "operator_name",
        "problem_type",
        "tags"
      ],
      "properties": {
        "framework": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "operator_name": {
          "type": "string"
        },
        "problem_type": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": [
            "local",
            "docker",
            "remote_docker"
          ]
        },
        "tier": {
          "type": "string",
          "enum": [
            "cpu-deterministic",
            "single-gpu",
            "kernel-build",
            "cpu_python_overlay",
            "cpu_package_runtime",
            "cpu_source_snapshot_fuller",
            "cuda_declared",
            "cuda_python_overlay",
            "cuda_kernel_build",
            "hardware_specific"
          ]
        },
        "image": {
          "type": "string"
        },
        "image_digest": {
          "type": "string",
          "minLength": 1
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "gpus": {
          "type": "string",
          "minLength": 1
        },
        "digest_kind": {
          "type": "string",
          "enum": [
            "repo_digest",
            "local_image_id",
            "build_hash"
          ]
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "dockerfile": {
          "type": "string"
        },
        "build_context": {
          "type": "string"
        },
        "workspace_dir": {
          "type": "string"
        },
        "preflight_workdir": {
          "type": "string"
        },
        "python_executable": {
          "type": "string"
        },
        "preflight_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resource_requirements": {
          "type": "object",
          "additionalProperties": true
        },
        "source_loading": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "python_overlay",
                "prebuilt_source_image",
                "full_source_build",
                "inplace_build"
              ]
            },
            "installed_package": {
              "type": "string",
              "minLength": 1
            },
            "overlay_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "runtime_site_packages": {
              "type": "string",
              "minLength": 1
            },
            "sync_before_tests": {
              "type": "boolean"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "mode": {
                    "const": "python_overlay"
                  }
                }
              },
              "then": {
                "required": [
                  "installed_package",
                  "overlay_paths",
                  "runtime_site_packages",
                  "sync_before_tests"
                ]
              }
            }
          ]
        },
        "python_version": {
          "type": "string"
        },
        "os": {
          "type": "string"
        },
        "build_mode": {
          "type": "string",
          "enum": [
            "editable-python",
            "source-build",
            "prebuilt-wheel"
          ]
        },
        "hardware": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "device",
            "min_memory_gb"
          ],
          "properties": {
            "device": {
              "type": "string"
            },
            "min_memory_gb": {
              "type": "integer",
              "minimum": 1
            },
            "gpu_model": {
              "type": "string"
            },
            "cuda_version": {
              "type": "string"
            }
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "agent_visible": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_setup_commands",
        "known_constraints",
        "allowed_test_commands"
      ],
      "properties": {
        "repo_setup_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "known_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_test_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setup_commands",
        "fail_to_pass",
        "pass_to_pass",
        "test_command",
        "timeout_sec"
      ],
      "properties": {
        "setup_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fail_to_pass": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pass_to_pass": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "public_tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "test_command": {
          "type": "string"
        },
        "timeout_sec": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gold_patch"
      ],
      "properties": {
        "gold_patch": {
          "type": "string"
        },
        "test_patch": {
          "type": "string"
        },
        "hidden_test_patch": {
          "type": "string"
        },
        "public_test_patch": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "difficulty",
        "curation_status",
        "deterministic",
        "estimated_runtime_min"
      ],
      "properties": {
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "curation_status": {
          "type": "string",
          "enum": [
            "draft",
            "verified"
          ]
        },
        "deterministic": {
          "type": "boolean"
        },
        "estimated_runtime_min": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string"
        },
        "layer": {
          "type": "string",
          "enum": [
            "A",
            "B"
          ]
        },
        "admission_status": {
          "type": "string",
          "enum": [
            "candidate",
            "environment_ready",
            "source_ready",
            "baseline_reproduced",
            "gold_verified",
            "verified",
            "blocked",
            "blocked_environment",
            "blocked_source",
            "blocked_test",
            "not_reproduced",
            "gold_failed",
            "deprecated"
          ]
        },
        "source_loading_verified": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "not": {
          "required": ["environment_ref"]
        }
      },
      "then": {
        "properties": {
          "environment": {
            "required": [
              "tier",
              "image",
              "python_version",
              "os",
              "build_mode",
              "hardware",
              "dependencies"
            ]
          }
        }
      }
    }
  ]
}
