{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpBench source snapshot registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sources"],
  "properties": {
    "version": {"type": "string", "pattern": "^v[0-9]+$"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "repo_url", "commit", "submodules", "source_loading_modes", "related_tasks"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "repo_url": {"type": "string", "minLength": 1},
          "commit": {"type": "string", "minLength": 7},
          "local_path": {"type": ["string", "null"]},
          "checksum": {"type": ["string", "null"]},
          "submodules": {
            "type": "object",
            "additionalProperties": false,
            "required": ["policy", "status"],
            "properties": {
              "policy": {
                "type": "string",
                "enum": ["none_required", "partial", "full", "unknown"]
              },
              "status": {"type": "string", "minLength": 1}
            }
          },
          "source_loading_modes": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "related_tasks": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
