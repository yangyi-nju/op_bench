    "gpu-a100-lambda": {
      "user": "ubuntu",
      "hostname": "lambda-instance.example.com",
      "port": 22,
      "identity_file": "~/.ssh/lambda-key",
      "remote_workspace_root": "/home/ubuntu/op_bench_workspaces"
    }
  }
}
