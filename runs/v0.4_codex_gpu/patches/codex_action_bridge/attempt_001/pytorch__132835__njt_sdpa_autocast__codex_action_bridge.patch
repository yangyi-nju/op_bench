+def _autocast_sdpa_nested_inputs(query, key, value):
+    device_type = query.device.type
+    if key.device.type != device_type or value.device.type != device_type:
+        return query, key, value
+    if not torch.is_autocast_enabled(device_type):
+        return query, key, value
+
+    target_dtype = torch.get_autocast_dtype(device_type)
+
+    def maybe_to_autocast_dtype(tensor):
+        # Autocast SDPA casts fp16/bf16/fp32 inputs to the autocast dtype, but
+        # leaves fp64 inputs alone.
+        if tensor.is_floating_point() and tensor.dtype != torch.float64:
+            return tensor.to(target_dtype)
+        return tensor
+
+    return tuple(maybe_to_autocast_dtype(t) for t in (query, key, value))
+
